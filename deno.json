{
  "name": "@lu-zero/bun-compat",
  "version": "0.2.2",
  "exports": {
    ".": "./src/index.ts",
    "./bun": "./src/from-bun.ts",
    "./install": "./src/install.ts",
    "./sqlite": "./src/sqlite.ts",
    "./ffi": "./src/ffi.ts",
    "./ffi-structs": "./src/ffi-structs.ts"
  },
  "publish": {
    "exclude": ["test/", ".github/"]
  },
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true
  },
  "imports": {
    "@std/toml": "jsr:@std/toml@^1.0",
    "@std/yaml": "jsr:@std/yaml@^1.0",
    "@std/jsonc": "jsr:@std/jsonc@^1.0",
    "@std/fs": "jsr:@std/fs@^1.0",
    "@std/semver": "jsr:@std/semver@^1.0",
    "@std/cli": "jsr:@std/cli@^1.0",
    "@std/path": "jsr:@std/path@^1.0",
    "@std/media-types": "jsr:@std/media-types@^1.0",
    "@std/assert": "jsr:@std/assert@^1.0",
    "bun": "./src/from-bun.ts"
  },
  "tasks": {
    "test": "deno test --allow-all --unstable-ffi test/",
    "check": "deno check src/index.ts"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any",
        "no-empty",
        "require-await",
        "prefer-const",
        "no-unused-vars"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "singleQuote": false,
    "semiColons": true
  }
}
